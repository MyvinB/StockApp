# Groww API credentials (from https://groww.in/trade-api/api-keys)
# Generate TOTP token → you get GROWW_API_KEY (JWT) and GROWW_TOTP_SECRET (base32)
GROWW_API_KEY=your_totp_token_jwt_here
GROWW_API_SECRET=
GROWW_TOTP_SECRET=your_base32_totp_secret_here

# Email notifications (Gmail: enable "App Passwords" in Google account)
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
NOTIFY_EMAIL=recipient@email.com

# SMS notifications (Twilio - free trial gives $15 credit)
TWILIO_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890
NOTIFY_PHONE=+91XXXXXXXXXX
